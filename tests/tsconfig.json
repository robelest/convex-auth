{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "types": ["vite-plus/client", "node"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "lib": ["ES2022", "DOM"],
    "paths": {
      "@convex/*": ["../convex/*"],
      "@robelest/convex-auth/test": ["../packages/auth/src/test.ts"],
      "@robelest/convex-auth/*": ["../packages/auth/src/*"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}
