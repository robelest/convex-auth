{
  "name": "@robelest/samlify",
  "version": "0.0.1-preview.0",
  "private": true,
  "description": "Edge-compatible SAML 2.0 runtime used by convex-auth",
  "license": "MIT",
  "type": "module",
  "main": "./index.ts",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.ts"
    }
  },
  "scripts": {
    "build": "vp exec tsc -p ./tsconfig.build.json",
    "test": "vp test --root ../.. --project samlify",
    "test:once": "vp test --root ../.. --run --project samlify",
    "check:runtime-imports": "vp exec node ./scripts/check-forbidden-runtime-imports.mjs",
    "report:edge-gaps": "vp exec node ./scripts/report-edge-runtime-gaps.mjs"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.8.11",
    "camelcase": "^6.3.0",
    "fflate": "^0.8.2",
    "fontoxpath": "^3.33.0",
    "jsrsasign": "^11.1.0",
    "uuid": "^8.3.2",
    "xml-escape": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.2",
    "timekeeper": "^2.3.1",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  }
}
