{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["esnext", "dom"],
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "noEmit": true,
    "paths": {
      "@convex/*": ["../../convex/*"],
      "@robelest/convex-auth/permissions": ["./src/permissions/index"],
      "@robelest/convex-auth/browser": ["./src/browser/index"],
      "@robelest/convex-auth/client": ["./src/client/index"],
      "@robelest/convex-auth/component": ["./src/component/index"],
      "@robelest/convex-auth/convex.config": ["./src/component/convex.config"],
      "@robelest/convex-auth/errors": ["./src/server/errors"],
      "@robelest/convex-auth/expo": ["./src/expo/index"],
      "@robelest/convex-auth/server": ["./src/server/index"],
      "@robelest/convex-auth/providers": ["./src/providers/index"],
      "@robelest/convex-auth/providers/*": ["./src/providers/*"]
    }
  },
  "include": ["consumer/**/*.ts"]
}
