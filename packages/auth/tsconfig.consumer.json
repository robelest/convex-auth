{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["esnext", "dom"],
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "noEmit": true,
    "paths": {
      "@robelest/convex-auth/client": ["./src/client/index"],
      "@robelest/convex-auth/component": ["./src/component/index"],
      "@robelest/convex-auth/convex.config": ["./src/component/convex.config"],
      "@robelest/convex-auth/errors": ["./src/server/errors"],
      "@robelest/convex-auth/providers": ["./src/providers/index"],
      "@robelest/convex-auth/providers/*": ["./src/providers/*"]
    }
  },
  "include": ["consumer-typecheck/**/*.ts"]
}
