{
  "name": "@robelest/convex-auth",
  "version": "0.0.4-preview.40",
  "description": "Authentication for Convex",
  "keywords": [
    "auth",
    "authentication",
    "authorization",
    "convex"
  ],
  "homepage": "https://auth.estifanos.com/",
  "bugs": "https://github.com/robelest/convex-auth/issues",
  "license": "Apache-2.0",
  "author": "robelest",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robelest/convex-auth.git"
  },
  "bin": "./dist/bin.js",
  "files": [
    "dist",
    "!dist/**/*.map",
    "!dist/index.js",
    "!dist/model.d.ts",
    "!dist/model.d.ts.map",
    "!dist/schema.d.ts",
    "!dist/schema.d.ts.map"
  ],
  "type": "module",
  "sideEffects": [
    "./src/server/identity/convex.ts",
    "./dist/server/identity/convex.js"
  ],
  "exports": {
    "./_generated/component.js": {
      "types": "./dist/component/_generated/component.d.ts"
    },
    "./test": {
      "types": "./dist/test.d.ts",
      "import": "./dist/test.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./browser": {
      "types": "./dist/browser/index.d.ts",
      "import": "./dist/browser/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./expo": {
      "types": "./dist/expo/index.d.ts",
      "import": "./dist/expo/index.js"
    },
    "./otel": {
      "types": "./dist/otel.d.ts",
      "import": "./dist/otel.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./component": {
      "types": "./dist/component/index.d.ts",
      "import": "./dist/component/index.js"
    },
    "./permissions": {
      "types": "./dist/permissions/index.d.ts",
      "import": "./dist/permissions/index.js"
    },
    "./convex.config": {
      "types": "./dist/component/convex.config.d.ts",
      "import": "./dist/component/convex.config.js",
      "default": "./dist/component/convex.config.js"
    },
    "./convex.config.js": {
      "types": "./dist/component/convex.config.d.ts",
      "import": "./dist/component/convex.config.js",
      "default": "./dist/component/convex.config.js"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "import": "./dist/providers/index.js"
    },
    "./providers/*": {
      "types": "./dist/providers/*.d.ts",
      "import": "./dist/providers/*.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:lib": "vp exec tsdown",
    "build": "rm -rf dist && vp run build:lib",
    "typecheck": "vp exec tsc --project tsconfig.server.json --noEmit && vp exec tsc --project tsconfig.client.json --noEmit && vp exec tsc --project tsconfig.component.json --noEmit",
    "typecheck:consumer": "vp exec tsc --project tsconfig.consumer.json --noEmit",
    "check:attw": "vp exec attw --pack . --profile esm-only --exclude-entrypoints ./test ./_generated/component.js",
    "check:publint": "vp exec publint --strict",
    "check:packaging": "vp run check:attw && vp run check:publint",
    "check:component-paginate": "node ../../scripts/check-component-paginate.mjs",
    "docs": "vp run --cwd ../../docs dev",
    "lint": "vp run typecheck",
    "spellcheck": "cspell \"docs/pages/**/*.md*\"",
    "prepublishOnly": "vp run build && vp run typecheck:consumer && vp run check:packaging",
    "test": "vp test --config ../../vite.config.ts --project convex --project node --project interop",
    "test:once": "vp test --config ../../vite.config.ts --run --project convex --project node --project interop",
    "convex:dev": "vp exec convex dev",
    "convex:codegen": "vp exec convex codegen",
    "convex:codegen:component": "vp exec convex codegen --component-dir ./src/component",
    "convex:dashboard": "vp exec convex dashboard",
    "convex:run": "vp exec convex run"
  },
  "dependencies": {
    "@convex-dev/action-cache": "^0.3.0",
    "@convex-dev/migrations": "^0.3.4",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@convex-dev/stream": "https://pkg.pr.new/get-convex/stream/@convex-dev/stream@96acc6d",
    "@convex-dev/workpool": "^0.4.6",
    "@noble/hashes": "^2.0.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-logs": "^0.214.0",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@opentelemetry/sdk-trace-node": "^2.6.1",
    "@opentelemetry/sdk-trace-web": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@oslojs/crypto": "^1.0.1",
    "@oslojs/encoding": "^1.1.0",
    "@oslojs/otp": "^1.1.0",
    "@oslojs/webauthn": "^1.0.0",
    "@xmldom/xmldom": "^0.8.11",
    "arctic": "^3.7.0",
    "camelcase": "^6.3.0",
    "convex-helpers": "^0.1.118",
    "cookie": "^1.1.1",
    "fflate": "^0.8.2",
    "jose": "^6.1.3",
    "jwt-decode": "^4.0.0",
    "uuid": "^8.3.2",
    "xml-escape": "^1.1.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@clack/prompts": "^1.2.0",
    "@types/figlet": "^1.7.0",
    "@types/node": "25.2.2",
    "@types/react": "^19.0.0",
    "@types/xml-escape": "^1.1.3",
    "convex": "catalog:",
    "convex-test": "catalog:",
    "cspell": "^9.6.4",
    "dotenv": "^17.2.4",
    "esbuild": "^0.27.3",
    "expo": "^55.0.15",
    "expo-auth-session": "^55.0.14",
    "expo-secure-store": "^55.0.13",
    "expo-web-browser": "^55.0.14",
    "figlet": "^1.11.0",
    "gradient-string": "^3.0.0",
    "publint": "^0.3.17",
    "react-native": "^0.85.2",
    "react-native-passkey": "^3.3.3",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "convex": "^1.41.0",
    "expo-auth-session": "*",
    "expo-secure-store": "*",
    "expo-web-browser": "*",
    "react-native": "*",
    "react-native-passkey": "*"
  },
  "peerDependenciesMeta": {
    "expo-auth-session": {
      "optional": true
    },
    "expo-secure-store": {
      "optional": true
    },
    "expo-web-browser": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "react-native-passkey": {
      "optional": true
    }
  },
  "@comment devDependencies": [
    "The CLI deps (Effect and @effect/platform-node) are devDependencies",
    "because they are bundled into dist/bin.js"
  ]
}
