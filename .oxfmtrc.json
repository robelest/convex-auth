{
  "proseWrap": "always",
  "printWidth": 80,
  "sortImports": {},
  "ignorePatterns": [
    "**/dist/**",
    "**/_generated/**",
    "**/node_modules/**",
    "**/.output/**",
    "**/routeTree.gen.ts",
    "packages/samlify/**",
    "pnpm-lock.yaml"
  ],
  "overrides": [
    {
      "files": ["examples/tanstack/**/*.{ts,tsx,js,jsx}"],
      "options": {
        "semi": false,
        "singleQuote": true,
        "trailingComma": "all"
      }
    }
  ]
}
